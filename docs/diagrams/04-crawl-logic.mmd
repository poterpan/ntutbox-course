flowchart TD
    A["crawl --terms X [--force]"] --> B["expand_terms(X)<br/>例 90-1:115-1 → 51 個學期清單"]
    B --> C{"逐學期"}
    C --> D{"canonical/{term}/<br/>catalog.ndjson 已存在?"}
    D -->|"否 (沒抓過)"| F["爬這學期"]
    D -->|"是 + 無 --force"| S["跳過 (resume)<br/>不爬·不寫"]
    D -->|"是 + --force"| F
    S --> C

    F --> G["crawl_term: 整學期全爬 ~135 請求<br/>Subj-2 系所 → 各系所 Subj-3+QueryCourse → 13 學制碼"]
    G --> H["write_canonical<br/>結構 catalog.ndjson + classes.json"]
    H --> I["write_enrollment_snapshot<br/>enrollment/{today}.ndjson"]
    I --> C

    C -->|"清單跑完"| J["build_v1<br/>從【全部】canonical 重建 v1 + manifest"]

    classDef skip fill:#fde68a,stroke:#b45309,color:#000
    classDef crawl fill:#bfdbfe,stroke:#1e40af,color:#000
