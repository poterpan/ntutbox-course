# --- secrets / 個資 (公開 repo 嚴禁) ---
.env
.env.*
*.local
secrets/
*.key

# --- Node / Next.js ---
node_modules/
.next/
out/
dist/
build/
.turbo/
*.tsbuildinfo
.vercel/
coverage/

# --- Python (crawler) ---
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- 爬蟲產生物 (發佈到 R2，不進 git；canonical NDJSON 例外，見 crawler/) ---
crawler/dist/
crawler/.scratch/
data/*-log-*.txt
# v1 JSON artifacts = R2 發佈目標，由 CI 重生+推送，可由爬蟲/rederive 重產 → 不進 git
# （canonical NDJSON 例外，進 git 留 enrollment 時序）
data/v1/
*.sqlite
*.sqlite-*

# --- OS / editor ---
.DS_Store
Thumbs.db
.idea/
.vscode/
